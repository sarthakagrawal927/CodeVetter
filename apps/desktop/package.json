{
  "name": "@code-reviewer/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:sidecar": "cd src-tauri/sidecar && bun build src/main.ts --compile --outfile review-sidecar && cp review-sidecar ../review-sidecar-$(rustc -vV | grep host | awk '{print $2}')",
    "tauri": "tauri",
    "tauri:dev": "npm run build:sidecar && tauri dev",
    "tauri:build": "npm run build:sidecar && tauri build"
  },
  "dependencies": {
    "@code-reviewer/shared-types": "file:../../packages/shared-types",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-sql": "^2.2.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
