#!/bin/sh

echo "Running pre-push checks..."

# ESLint
echo "  Linting desktop app..."
npx eslint apps/desktop/src/ --ext .ts,.tsx --quiet --max-warnings 0 2>/dev/null || echo "  ESLint warnings (non-blocking)"

# Build desktop frontend
echo "  Building desktop frontend..."
cd apps/desktop && npm run build || exit 1
cd ../..

echo "Pre-push checks passed"
